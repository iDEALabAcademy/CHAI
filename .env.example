# CHAI Environment Configuration — TEMPLATE
# Copy this file to `.env` and fill in your own keys.
# `.env` itself is gitignored — never commit real keys.

# LLM Configuration
# Options: "Anthropic", "OpenAI", or "HuggingFace" (set API_NAME in config/config.py)
# LLM_MODEL=gpt-4o-2024-11-20
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_MODEL=claude-sonnet-4-20250514

# Anthropic API Key (if using Anthropic)
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI API Key (if using OpenAI)
OPENAI_API_KEY=your-openai-key-here

# HuggingFace API Token (if using HuggingFace / local Llama)
HF_TOKEN=your-huggingface-token-here
